# macOS
.DS_Store

# Track Claude Code settings in this repo (overrides global ignore)
!.claude/settings.local.json

# Playwright MCP session artifacts (screenshots, console logs, page snapshots)
.playwright-mcp/

# Playwright MCP config — generated by .devcontainer/post-create.sh with the
# machine-specific path to the installed chromium binary (version suffix drifts)
.playwright-mcp.config.json

# Stray Playwright screenshots at repo root (from before --output-dir was set)
/*-page.png
/*-page-*.png
/*-section.png
